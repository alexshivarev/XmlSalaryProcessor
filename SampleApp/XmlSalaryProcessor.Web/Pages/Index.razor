@page "/"
@using System.Xml.Linq
@using System.Text
@inject IJSRuntime JS

<h3>Salary Processor Web</h3>

<div class="row">
    <div class="col-md-6">
        <InputFile OnChange="OnFileSelected" />
        <button class="btn btn-primary mt-2" @onclick="ProcessFile" disabled="@processing">Обработать</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(log))
{
    <div class="row mt-3">
        <div class="col">
            <pre>@log</pre>
        </div>
    </div>
}

@if (summaryData != null && summaryData.Any())
{
    <div class="row mt-3">
        <div class="col">
            <h4>Сводка по сотрудникам</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Фамилия</th>
                        <th>Суммарная зарплата</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in summaryData)
                    {
                        <tr>
                            <td>@emp.Name</td>
                            <td>@emp.Surname</td>
                            <td>@emp.SumSalary.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <button class="btn btn-success" @onclick="DownloadEmployeesXml">Скачать Employees.xml</button>
        </div>
    </div>
}

@code {
    private IBrowserFile selectedFile;
    private bool processing = false;
    private string log = "";
    private List<EmployeeSummary> summaryData;
    private XDocument generatedEmployeesDoc;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        log = $"Выбран файл: {selectedFile.Name} ({selectedFile.Size} bytes)";
    }

private async Task ProcessFile()
{
    if (selectedFile == null)
    {
        log = "Выберите файл.";
        return;
    }

    processing = true;
    log = "Обработка...";

    try
    {
        // Асинхронно читаем весь файл в MemoryStream
        using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        memoryStream.Position = 0; // Сбрасываем позицию в начало

        // Теперь можно синхронно загрузить XDocument из MemoryStream
        var sourceDoc = XDocument.Load(memoryStream);

        // 1. Добавляем атрибут SumAmount в корневой элемент исходного документа
        SalaryProcessor.AddSumAmountToXDocument(sourceDoc);
        log += $"\nАтрибут SumAmount добавлен: {sourceDoc.Root?.Attribute("SumAmount")?.Value}";

        // 2. Генерируем Employees.xml в памяти через библиотечный метод
        generatedEmployeesDoc = SalaryProcessor.GenerateEmployeesDocument(sourceDoc);
        log += "\nEmployees.xml сгенерирован.";

        // 3. Формируем сводку для таблицы (из сгенерированного документа)
        summaryData = new List<EmployeeSummary>();
        var root = generatedEmployeesDoc.Root;
        if (root != null)
        {
            foreach (var emp in root.Elements("Employee"))
            {
                summaryData.Add(new EmployeeSummary
                {
                    Name = emp.Attribute("name")?.Value ?? "",
                    Surname = emp.Attribute("surname")?.Value ?? "",
                    SumSalary = decimal.Parse(emp.Attribute("SumSalary")?.Value ?? "0", System.Globalization.CultureInfo.InvariantCulture)
                });
            }
        }

        log += "\nОбработка завершена успешно!";
    }
    catch (Exception ex)
    {
        log += $"\nОшибка: {ex.Message}";
    }
    finally
    {
        processing = false;
    }
}

    private async Task DownloadEmployeesXml()
    {
        if (generatedEmployeesDoc == null) return;

        var xmlString = generatedEmployeesDoc.ToString();
        var bytes = Encoding.UTF8.GetBytes(xmlString);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", "Employees.xml", base64);
    }

    public class EmployeeSummary
    {
        public string Name { get; set; }
        public string Surname { get; set; }
        public decimal SumSalary { get; set; }
    }
}