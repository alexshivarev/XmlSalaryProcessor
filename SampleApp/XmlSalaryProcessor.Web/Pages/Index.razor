@page "/"
@using System.Xml.Linq
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Salary Processor — сводка по сотрудникам и месяцам</h2>
        </div>
        <div class="card-body">
            <p class="lead">Загрузите XML файл (Data1.xml или Data2.xml). Программа покажет таблицу сотрудников с суммами выплат по каждому месяцу.</p>

            <div class="mb-4">
                <label class="form-label fw-bold">Выберите XML-файл</label>
                <InputFile OnChange="OnFileSelected" accept=".xml" class="form-control" />
                <div class="form-text">Файлы до 10 МБ</div>
            </div>

            <div class="d-grid gap-2 d-md-block">
                <button class="btn btn-primary" @onclick="ProcessFile" disabled="@(selectedFile == null || processing)">
                    @(processing ? "Обработка..." : "Запустить программу")
                    @if (processing)
                    {
                        <span class="spinner-border spinner-border-sm ms-2" role="status"></span>
                    }
                </button>
            </div>

            @if (summaryData != null && summaryData.Any())
            {
                <hr />
                <h4 class="mt-3">Сводка по сотрудникам</h4>
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Сотрудник</th>
                                @foreach (var month in allMonths)
                                {
                                    <th>@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(month)</th>
                                }
                                <th>Итого (SumSalary)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in summaryData)
                            {
                                <tr>
                                    <td><strong>@emp.Name @emp.Surname</strong></td>
                                    @foreach (var month in allMonths)
                                    {
                                        var amount = emp.MonthlySum.ContainsKey(month) ? emp.MonthlySum[month] : 0m;
                                        <td>@amount.ToString("N2", CultureInfo.InvariantCulture)</td>
                                    }
                                    <td><strong>@emp.TotalSalary.ToString("N2", CultureInfo.InvariantCulture)</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <button class="btn btn-secondary me-2" @onclick="DownloadEmployeesFile">📄 Скачать Employees.xml</button>
                    <button class="btn btn-success" @onclick="DownloadUpdatedOriginal">📥 Скачать обновлённый входной файл</button>
                </div>
            }
            else if (processed && (summaryData == null || !summaryData.Any()))
            {
                <div class="alert alert-warning mt-3">Нет данных для отображения. Файл не содержит элементов &lt;item&gt;.</div>
            }

            @if (!string.IsNullOrEmpty(log))
            {
                <div class="card mt-4">
                    <div class="card-header bg-secondary text-white">Лог выполнения</div>
                    <div class="card-body p-0">
                        <pre class="bg-light p-3 mb-0" style="max-height: 300px; overflow: auto;">@log</pre>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private bool processing = false;
    private bool processed = false;
    private string log = "";
    private byte[]? updatedOriginalContent;
    private byte[]? employeesContent;
    private List<EmployeeSummary>? summaryData;
    private List<string> allMonths = new List<string>();

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        log = "";
        processed = false;
        summaryData = null;
        updatedOriginalContent = null;
        employeesContent = null;
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (selectedFile == null) return;
        processing = true;
        log = "";
        AppendLog("Загрузка файла...");
        try
        {
            using var memoryStream = new MemoryStream();
            await selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);
            memoryStream.Position = 0;
            var originalBytes = memoryStream.ToArray();

            var (updatedXmlBytes, employeesBytes, summary) = ProcessXml(originalBytes);
            updatedOriginalContent = updatedXmlBytes;
            employeesContent = employeesBytes;
            summaryData = summary;
            processed = true;

            // Собираем все месяцы из данных для заголовков таблицы
            allMonths = summaryData
                .SelectMany(e => e.MonthlySum.Keys)
                .Distinct()
                .OrderBy(m => GetMonthNumber(m))
                .ToList();

            AppendLog($"Обработка завершена. Найдено {summaryData.Count} сотрудников.");
        }
        catch (Exception ex)
        {
            AppendLog($"Ошибка: {ex.Message}");
        }
        finally
        {
            processing = false;
        }
    }

    private (byte[] UpdatedOriginal, byte[] EmployeesXml, List<EmployeeSummary> Summary) ProcessXml(byte[] inputFileBytes)
    {
        XDocument doc;
        using (var stream = new MemoryStream(inputFileBytes))
        {
            doc = XDocument.Load(stream);
        }

        // 1. Добавляем SumAmount
        var root = doc.Root;
        if (root != null && root.Name.LocalName == "Pay")
        {
            decimal totalSum = 0m;
            var allItems = doc.Descendants("item");
            foreach (var item in allItems)
                totalSum += ParseAmountDecimal((string)item.Attribute("amount"));
            decimal roundedTotal = Math.Round(totalSum, 2, MidpointRounding.AwayFromZero);
            var attr = root.Attribute("SumAmount");
            if (attr == null) root.Add(new XAttribute("SumAmount", roundedTotal.ToString(CultureInfo.InvariantCulture)));
            else attr.Value = roundedTotal.ToString(CultureInfo.InvariantCulture);
            AppendLog($"Добавлен SumAmount = {roundedTotal}");
        }

        // 2. Преобразование в Employees.xml и сбор сводки
        var items = doc.Descendants("item");
        var groups = items.GroupBy(item => new { Name = (string)item.Attribute("name"), Surname = (string)item.Attribute("surname") });

        XDocument employeesDoc = new XDocument(new XElement("Employees"));
        var employeesRoot = employeesDoc.Root;
        var summaryList = new List<EmployeeSummary>();

        foreach (var group in groups)
        {
            string name = group.Key.Name;
            string surname = group.Key.Surname;

            XElement employeeXml = new XElement("Employee",
                new XAttribute("name", name),
                new XAttribute("surname", surname));

            decimal totalSalary = 0m;
            var monthSumDict = new Dictionary<string, decimal>();

            foreach (var item in group)
            {
                string month = GetCorrectMount(item);
                string amountStr = (string)item.Attribute("amount");
                decimal amount = ParseAmountDecimal(amountStr);
                totalSalary += amount;

                if (monthSumDict.ContainsKey(month))
                    monthSumDict[month] += amount;
                else
                    monthSumDict[month] = amount;

                employeeXml.Add(new XElement("salary",
                    new XAttribute("amount", amountStr),
                    new XAttribute("mount", month)));
            }

            decimal roundedTotal = Math.Round(totalSalary, 2, MidpointRounding.AwayFromZero);
            employeeXml.Add(new XAttribute("SumSalary", roundedTotal.ToString(CultureInfo.InvariantCulture)));
            employeesRoot!.Add(employeeXml);

            summaryList.Add(new EmployeeSummary
            {
                Name = name,
                Surname = surname,
                TotalSalary = roundedTotal,
                MonthlySum = monthSumDict
            });
            AppendLog($"Сотрудник {name} {surname}: выплат за {monthSumDict.Count} месяцев, итого {roundedTotal}");
        }

        // Сохраняем в байтовые массивы
        byte[] updatedOriginalBytes;
        using (var ms = new MemoryStream()) { doc.Save(ms); updatedOriginalBytes = ms.ToArray(); }

        byte[] employeesBytes;
        using (var ms = new MemoryStream()) { employeesDoc.Save(ms); employeesBytes = ms.ToArray(); }

        return (updatedOriginalBytes, employeesBytes, summaryList);
    }

    private string GetCorrectMount(XElement item)
    {
        var parent = item.Parent;
        if (parent != null && parent.Name.LocalName == "Pay")
            return (string)item.Attribute("mount");
        else
            return parent?.Name.LocalName ?? "";
    }

    private decimal ParseAmountDecimal(string amountStr)
    {
        if (string.IsNullOrEmpty(amountStr)) return 0m;
        string normalized = amountStr.Replace(',', '.');
        if (decimal.TryParse(normalized, NumberStyles.Any, CultureInfo.InvariantCulture, out decimal result))
            return result;
        return 0m;
    }

    private void AppendLog(string message)
    {
        log += $"{DateTime.Now:HH:mm:ss} - {message}\n";
        InvokeAsync(StateHasChanged);
    }

    private async Task DownloadUpdatedOriginal()
    {
        if (updatedOriginalContent != null)
            await JS.InvokeVoidAsync("saveAsFile", "Data_updated.xml", Convert.ToBase64String(updatedOriginalContent));
    }

    private async Task DownloadEmployeesFile()
    {
        if (employeesContent != null)
            await JS.InvokeVoidAsync("saveAsFile", "Employees.xml", Convert.ToBase64String(employeesContent));
    }

    private int GetMonthNumber(string monthName)
    {
        return monthName.ToLower() switch
        {
            "january" => 1, "february" => 2, "march" => 3, "april" => 4,
            "may" => 5, "june" => 6, "july" => 7, "august" => 8,
            "september" => 9, "october" => 10, "november" => 11, "december" => 12,
            _ => 99
        };
    }

    public class EmployeeSummary
    {
        public string Name { get; set; } = "";
        public string Surname { get; set; } = "";
        public decimal TotalSalary { get; set; }
        public Dictionary<string, decimal> MonthlySum { get; set; } = new();
    }
}